{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noEmitOnError": true,
    "types": ["node"]
  },
  "include": [
    "main.ts",
    "preload.ts",
    "popout-preload.ts",
    "src/electron-api.d.ts",
    "src/adm-zip.d.ts"
  ],
  "exclude": ["dist", "node_modules"]
}
